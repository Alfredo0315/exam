<Window x:Class="ExamProgramm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ExamProgramm"
        Title="Данные о людях" Height="700" Width="1000">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Количество человек:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="CountTextBox" Width="60" Text="5" VerticalAlignment="Center"/>
                <Button x:Name="CreateRowsButton" Content="Создать строки для ввода"
                        Margin="12,0,0,0" Padding="8,4" Click="CreateRowsButton_Click"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Text="Сортировать по:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <RadioButton x:Name="SortByYear" Content="Году рождения"
                             GroupName="SortField" IsChecked="True" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <RadioButton x:Name="SortBySurname" Content="Фамилии"
                             GroupName="SortField" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button x:Name="SortButton" Content="Отсортировать"
                        Padding="8,4" Click="SortButton_Click"/>
            </StackPanel>

            <Rectangle Height="1" Fill="LightGray" Margin="0,12,0,10"/>



            <Rectangle Height="1" Fill="LightGray" Margin="0,0,0,10"/>


            <Button x:Name="RandomFillButton" Content="Заполнить"
                    Padding="8,4" HorizontalAlignment="Left" Click="RandomFillButton_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="1" x:Name="StatusTextBlock" Foreground="DarkRed" Margin="0,0,0,10" TextWrapping="Wrap"/>


        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,6,0">

                <DataGrid x:Name="InputDataGrid" Height="380" AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Фамилия" Binding="{Binding Surname, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                        <DataGridTextColumn Header="Имя" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridTextColumn Header="Год рождения" Width="*">
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                <TextBlock x:Name="SortedHeaderTextBlock" Text="Отсортированный набор" FontWeight="Bold"/>
                <DataGrid x:Name="SortedDataGrid" Height="380" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Фамилия" Binding="{Binding Suranme}" Width="2*"/>
                        <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Год рождения" Binding="{Binding Year, StringFormat=\{0:0.0\}}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Grid>
    </Grid>
</Window>