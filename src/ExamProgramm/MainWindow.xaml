<Window x:Class="ExamProgramm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление данными о людях" Height="600" Width="900">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

      
        <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Количество элементов:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="TxtArraySize" Width="60" Margin="0,0,20,0" Text="5"/>

                <Button x:Name="BtnSetSize" Content="Загрузить данные" Click="BtnSetSize_Click" Margin="0,0,10,0"/>

                <Separator Width="20" Background="Transparent"/>

                <Button x:Name="BtnShowUnsorted" Content="Показать исходный список" Click="BtnShowUnsorted_Click" Margin="0,0,10,0" IsEnabled="False"/>
                

                <Separator Width="20" Background="Transparent"/>

                <Button x:Name="BtnSortAndShow" Content="Отсортировать" Click="BtnSortAndShow_Click" />
                <Button x:Name="BtnSaveToFile" Content="Сохранить результат" Click="BtnSaveToFile_Click" />

               
            </StackPanel>
        </Border>

       
        <GroupBox Grid.Row="1" Header="Неотсортированный набор" Margin="0,0,0,10">
            <DataGrid x:Name="DgUnsorted" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="*"/>
                    <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="*"/>
                    <DataGridTextColumn Header="Год рождения" Binding="{Binding BirthYear}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

       
        <Border Grid.Row="2" Background="#F0F0F0" Padding="5" Margin="0,10,0,10">
            <TextBlock x:Name="LblStatus" 
                       Text="" 
                       FontWeight="Bold" 
                       VerticalAlignment="Center"/>
        </Border>

      
        <GroupBox Grid.Row="3" Header="Результат сортировки" Margin="0,0,0,0">
            <DataGrid x:Name="DgSorted" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="*"/>
                    <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="*"/>
                    <DataGridTextColumn Header="Год рождения" Binding="{Binding BirthYear}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</Window>
